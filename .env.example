# ==============================================================================
# PROJECT EUREKA - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Settings (FastAPI)
# ------------------------------------------------------------------------------
# App environment: development | production | staging
APP_ENV=development
APP_NAME="Project Eureka"
DEBUG=true

# Database configurations (Dual-Database Strategy)
# - Local dev: defaults to SQLite "sqlite+aiosqlite:///./data/eureka.db"
# - Production: configure async PostgreSQL connection URL below
# DATABASE_URL=postgresql+asyncpg://eureka_user:secure_password@localhost:5432/eureka

# JWT Authentication secret key (Must be random, secure 64-character string in prod)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS origins - Comma-separated allowed frontend URLs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Structured logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# NVIDIA NIM & Riva Integrations
# ------------------------------------------------------------------------------
# Institutional NVIDIA NIM API key obtained from build.nvidia.com
NVIDIA_NIM_API_KEY=nvapi-xxxx

# Optional: Translation or Admin tasks API Key overrides
NVIDIA_CHAT_API_KEY=
NVIDIA_NEMO_API_KEY=

# NVIDIA Riva Speech API endpoints
NVIDIA_RIVA_API_KEY=
NVIDIA_RIVA_ENDPOINT=riva-api.nvidia.com:443

# ------------------------------------------------------------------------------
# Optional Vector Search & Storage (Supabase)
# ------------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

SUPABASE_URL=
SUPABASE_ANON_KEY=

# ------------------------------------------------------------------------------
# Frontend Settings (Next.js)
# ------------------------------------------------------------------------------
# Backend API URL that the Next.js frontend calls. Used on Vercel deployment.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
