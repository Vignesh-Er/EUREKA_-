# ============================================ # Project Eureka - Backend Environment Variables # ============================================ # Application APP_NAME="Project Eureka" APP_ENV=development DEBUG=True SECRET_KEY=your-super-secret-key-change-in-production # Database DATABASE_URL=postgresql://eureka:eureka_password@localhost:5432/eureka # For async: DATABASE_URL=postgresql+asyncpg://eureka:eureka_password@localhost:5432/eureka # Qdrant (Vector Database) QDRANT_HOST=localhost QDRANT_PORT=6333 QDRANT_API_KEY= # NVIDIA API Configuration NVIDIA_NEMO_API_KEY= NVIDIA_NIM_API_KEY= NVIDIA_RIVA_API_KEY= NVIDIA_RIVA_ENDPOINT=riva-api.nvidia.com:443 # JWT Authentication JWT_SECRET_KEY=your-jwt-secret-key JWT_ALGORITHM=HS256 JWT_EXPIRE_MINUTES=1440 # File Storage UPLOAD_DIR=./uploads MAX_UPLOAD_SIZE=104857600  # 100MB # CORS Settings CORS_ORIGINS=http://localhost:3000,http://localhost:8000 # Redis (for caching and sessions) REDIS_URL=redis://localhost:6379/0 # Logging LOG_LEVEL=INFO LOG_FORMAT=json